# ══════════════════════════════════════════════════════
# Shorts Factory v2.0 — Viral Intelligence Pipeline
# Copy this to .env and fill in your values
# ══════════════════════════════════════════════════════

# ── API Keys ──
GEMINI_API_KEY=your_gemini_api_key_here

# YouTube OAuth: place client_secret.json in project root,
# then run: python scripts/youtube_auth.py

# ── Channel Configuration ──
CHANNEL_TECH_NAME=Tech Explained
CHANNEL_AI_NAME=AI Insider

# ── Content Settings ──
DEFAULT_NICHE=tech
SHORTS_PER_RUN=3
VOICE_NAME=en-US-AndrewNeural
VOICE_RATE=+15%
BACKGROUND_MUSIC_VOLUME=0.12

# ── Upload Settings ──
AUTO_UPLOAD=false
UPLOAD_PRIVACY=private
SCHEDULE_HOURS_AHEAD=2

# ── Veo 3 Mode ──
# "manual"  = generates prompts, you paste into Veo 3 and drop clips
# "vertex"  = uses Vertex AI API (requires GCP project)
VEO_MODE=manual
GCP_PROJECT_ID=
GCP_LOCATION=us-central1

# ══════════════════════════════════════════════════════
# VIRAL INTELLIGENCE ENGINE (v2.0)
# ══════════════════════════════════════════════════════

# Virality Pre-Score Gate
# Scripts below threshold are killed before production
VIRALITY_GATE=true
VIRALITY_THRESHOLD=75
VIRALITY_MIN_THRESHOLD=60
MAX_IMPROVEMENT_ROUNDS=2

# Generate extra scripts then keep the best ones
# 1.5 = generate 50% more than needed, keep top N
OVERGENERATE_FACTOR=1.5

# ── Production Quality ──
VIDEO_CRF=20
VIDEO_PRESET=medium
AUDIO_BITRATE=192k
CAPTION_STYLE=tiktok_pop

# Sound Design (SFX + ambient background)
SOUND_DESIGN=true
SFX_VOLUME=0.4

# Visual enhancements
PROGRESS_BAR=true
COLOR_GRADE=true
CONTRAST_BOOST=1.05
SATURATION_BOOST=1.1

# ── Analytics ──
ANALYTICS=true
ANALYTICS_AUTO_PULL=true

# ── Multi-Channel ──
MULTI_CHANNEL=false
NICHE_ROTATION=false
