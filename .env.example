# ============================================
# Shorts Factory Configuration
# Copy this to .env and fill in your values
# ============================================

# Gemini API (get from ai.google.dev)
GEMINI_API_KEY=your_gemini_api_key_here

# YouTube OAuth (auto-populated after running youtube_auth.py)
# Just place client_secret.json in project root

# ---- Channel Configuration ----
CHANNEL_TECH_NAME=Tech Explained
CHANNEL_AI_NAME=AI Insider

# ---- Content Settings ----
DEFAULT_NICHE=tech
SHORTS_PER_RUN=3
VOICE_NAME=en-US-AndrewNeural
VOICE_RATE=+10%
BACKGROUND_MUSIC_VOLUME=0.12

# ---- Upload Settings ----
AUTO_UPLOAD=false
UPLOAD_PRIVACY=private
SCHEDULE_HOURS_AHEAD=2

# ---- Veo 3 Mode ----
# "manual"  = generates prompts, you paste into Veo 3 app and drop clips in output/video/
# "vertex"  = uses Vertex AI API (requires GCP project with Vertex AI enabled)
VEO_MODE=manual
# Only needed if VEO_MODE=vertex
GCP_PROJECT_ID=
GCP_LOCATION=us-central1
